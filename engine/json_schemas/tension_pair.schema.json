{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TensionPair",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pair_id",
    "idea_a",
    "idea_b",
    "proponent_agent",
    "challenger_agent",
    "tension_type",
    "tension_source",
    "priority",
    "shared_concepts",
    "signals"
  ],
  "properties": {
    "pair_id": { "type": "string", "minLength": 8 },
    "idea_a": { "type": "string", "minLength": 3 },
    "idea_b": { "type": "string", "minLength": 3 },
    "proponent_agent": { "type": "string", "enum": ["codex", "claude"] },
    "challenger_agent": { "type": "string", "enum": ["codex", "claude"] },
    "tension_type": {
      "type": "string",
      "enum": [
        "shared_frontier",
        "concept_graph_contradiction",
        "translation_strain",
        "audit_anomaly_overlap",
        "near_neighbor_conflict",
        "source_overlap_with_divergent_conclusion",
        "wildcard"
      ]
    },
    "tension_source": { "type": "string", "minLength": 3 },
    "priority": { "type": "number", "minimum": 0, "maximum": 1 },
    "shared_concepts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "weight", "reason"],
        "properties": {
          "name": { "type": "string", "minLength": 3 },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason": { "type": "string", "minLength": 3 }
        }
      }
    }
  }
}
