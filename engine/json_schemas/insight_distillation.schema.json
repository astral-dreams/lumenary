{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InsightDistillation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "insight",
    "plainSummary",
    "atAGlance",
    "keyPoints",
    "match",
    "tags"
  ],
  "properties": {
    "insight": {
      "type": "string",
      "minLength": 3,
      "maxLength": 90
    },
    "plainSummary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 220
    },
    "atAGlance": {
      "type": "string",
      "minLength": 80,
      "maxLength": 700
    },
    "keyPoints": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 12,
        "maxLength": 140
      }
    },
    "match": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 2
      }
    }
  }
}
