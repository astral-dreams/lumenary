{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DialogueCrux",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crux",
    "why_it_matters",
    "evidence_needed",
    "practitioner_test"
  ],
  "properties": {
    "crux": { "type": "string", "minLength": 10 },
    "why_it_matters": { "type": "string", "minLength": 10 },
    "evidence_needed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "practitioner_test": { "type": "string", "minLength": 10 }
  }
}
