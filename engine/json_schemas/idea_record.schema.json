{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IdeaRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "idea_type",
    "source_basis",
    "original_claim",
    "why_it_might_be_new",
    "critique",
    "epistemic_labels",
    "scores",
    "next_research_directions",
    "teaching_candidate",
    "practice_candidate",
    "tests"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 90
    },
    "idea_type": {
      "type": "string",
      "enum": [
        "observation",
        "hypothesis",
        "model",
        "bridge",
        "contradiction",
        "synthesis"
      ]
    },
    "source_basis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "original_claim": {
      "type": "string",
      "minLength": 40
    },
    "why_it_might_be_new": {
      "type": "string",
      "minLength": 20
    },
    "critique": {
      "type": "string",
      "minLength": 20
    },
    "epistemic_labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "textual",
          "interpretive",
          "phenomenological",
          "empirical-adjacent",
          "analogical",
          "speculative",
          "rejected"
        ]
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "novelty",
        "generativity",
        "cross_tradition_support",
        "logical_coherence",
        "explanatory_compression",
        "empirical_adjacency",
        "practice_testability",
        "counterargument_quality",
        "source_reliability",
        "publishability"
      ],
      "properties": {
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "generativity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cross_tradition_support": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "logical_coherence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "explanatory_compression": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "empirical_adjacency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "practice_testability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "counterargument_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_reliability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "publishability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "next_research_directions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "teaching_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "teaching_line",
        "doctrine_claim",
        "body",
        "target_human_problem",
        "target_cohort",
        "pressure_survived",
        "falsifying_pressure",
        "status",
        "tags"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3
        },
        "teaching_line": {
          "type": "string",
          "minLength": 8
        },
        "doctrine_claim": {
          "type": "string",
          "minLength": 30
        },
        "body": {
          "type": "string",
          "minLength": 80
        },
        "target_human_problem": {
          "type": "string",
          "minLength": 20
        },
        "target_cohort": {
          "type": "string",
          "minLength": 20
        },
        "pressure_survived": {
          "type": "string",
          "minLength": 20
        },
        "falsifying_pressure": {
          "type": "string",
          "minLength": 20
        },
        "status": {
          "type": "string",
          "enum": [
            "seed",
            "under_dialogue",
            "teaching_ready",
            "practice_linked",
            "revised",
            "weakened",
            "retired",
            "falsified"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "practice_candidate": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title",
            "practice_line",
            "purpose",
            "target_human_problem",
            "target_cohort",
            "non_fit",
            "duration",
            "frequency",
            "minimum_attempt",
            "steps",
            "notice",
            "caution",
            "weakens_if",
            "risk_level",
            "status",
            "tags"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3
            },
            "practice_line": {
              "type": "string",
              "minLength": 8
            },
            "purpose": {
              "type": "string",
              "minLength": 20
            },
            "target_human_problem": {
              "type": "string",
              "minLength": 20
            },
            "target_cohort": {
              "type": "string",
              "minLength": 20
            },
            "non_fit": {
              "type": "string",
              "minLength": 20
            },
            "duration": {
              "type": "string",
              "minLength": 2
            },
            "frequency": {
              "type": "string",
              "minLength": 2
            },
            "minimum_attempt": {
              "type": "string",
              "minLength": 2
            },
            "steps": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "string"
              }
            },
            "notice": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "caution": {
              "type": "string",
              "minLength": 15
            },
            "weakens_if": {
              "type": "string",
              "minLength": 20
            },
            "risk_level": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "seed",
                "under_dialogue",
            "published",
            "revised",
            "weakened",
            "retired",
            "falsified"
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "test_type",
          "target_type",
          "prediction",
          "result",
          "impact",
          "next_action",
          "status"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "test_type": {
            "type": "string",
            "enum": [
              "observational",
              "cross-domain",
              "practice-report",
              "prior-art",
              "safety",
              "falsification-attempt"
            ]
          },
          "target_type": {
            "type": "string",
            "enum": [
              "idea",
              "teaching",
              "practice"
            ]
          },
          "prediction": {
            "type": "string",
            "minLength": 20
          },
          "result": {
            "type": "string"
          },
          "impact": {
            "type": "string",
            "enum": [
              "pending",
              "strengthens",
              "weakens",
              "breaks",
              "revises",
              "inconclusive"
            ]
          },
          "next_action": {
            "type": "string",
            "minLength": 10
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "running",
              "complete",
              "abandoned"
            ]
          }
        }
      }
    }
  }
}
