---
import { formatLabel, type SourceCard } from "../lib/content";

type Props = {
  sources: SourceCard[];
};

const { sources } = Astro.props;
const sourceDomains = [
  {
    aliases: ["advaita", "vedanta", "hindu", "upanishad", "mandukya", "gaudapada"],
    label: "Advaita",
  },
  {
    aliases: ["buddh", "madhyamaka", "mahayana", "yogacara", "zen", "dogen"],
    label: "Buddhism",
  },
  {
    aliases: ["dao", "tao", "zhuangzi"],
    label: "Daoism",
  },
  {
    aliases: ["sufi", "ibn", "islamic", "rumi", "hallaj", "ghazali"],
    label: "Sufism",
  },
  {
    aliases: ["christian", "gospel", "john", "corinthians", "dionysius", "augustine", "desert-fathers"],
    label: "Christianity",
  },
  {
    aliases: ["judaism", "jewish", "hebrew", "genesis", "exodus", "ecclesiastes", "yetzirah", "zohar", "maimonides"],
    label: "Judaism",
  },
  {
    aliases: ["neoplat", "plotinus", "proclus"],
    label: "Neoplatonism",
  },
  {
    aliases: ["consciousness-science", "consciousness", "iit", "phenomenology"],
    label: "Consciousness Science",
  },
  {
    aliases: ["cognitive-science", "cognitive", "hoffman"],
    label: "Cognitive Science",
  },
  {
    aliases: ["computational-neuroscience", "neuroscience", "friston", "predictive"],
    label: "Neuroscience",
  },
  {
    aliases: ["high-energy-physics", "particle-data", "cern-physics", "standard-model"],
    label: "High Energy Physics",
  },
  {
    aliases: ["physics-time", "time-reversal", "minkowski", "einstein", "noether"],
    label: "Physics Of Time",
  },
  {
    aliases: ["matter-theory", "higgs", "strong-force", "quark", "mass-generation"],
    label: "Matter Theory",
  },
  {
    aliases: ["quantum-gravity-time", "quantum-gravity", "wheeler-dewitt", "rovelli", "page-and-wootters"],
    label: "Quantum Gravity",
  },
  {
    aliases: ["matter-antimatter", "antimatter", "baryon", "sakharov"],
    label: "Matter-Antimatter",
  },
  {
    aliases: ["particle-cosmology", "cosmology", "planck"],
    label: "Particle Cosmology",
  },
  {
    aliases: ["theoretical-physics", "physics-measurement", "physics", "quantum"],
    label: "Physics",
  },
  {
    aliases: ["project", "method", "lumenary"],
    label: "Method",
  },
];

function sourceDomain(source: SourceCard): string {
  const text = `${source.tradition} ${source.source_id} ${source.title} ${source.notes}`.toLowerCase();
  return sourceDomains.find((domain) => domain.aliases.some((alias) => text.includes(alias)))?.label || "Other";
}

const groupsByDomain = new Map<string, SourceCard[]>();
for (const source of sources) {
  const domain = sourceDomain(source);
  groupsByDomain.set(domain, [...(groupsByDomain.get(domain) || []), source]);
}
const groups = [
  ...sourceDomains.map((domain) => [domain.label, groupsByDomain.get(domain.label) || []] as const),
  ["Other", groupsByDomain.get("Other") || []] as const,
].filter(([, cards]) => cards.length > 0);
const total = sources.length;
---

<figure class="source-map" aria-label="Source foundation by tradition">
  <figcaption>
    <span>Source foundation</span>
    <strong>{total} cards</strong>
  </figcaption>
  <ul class="source-count-list">
    {groups.map(([tradition, cards]) => (
      <li>
        <a href="/sources/">
          <span>{formatLabel(tradition)}</span>
          <strong>{cards.length}</strong>
        </a>
      </li>
    ))}
  </ul>
</figure>
