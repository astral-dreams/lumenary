---
import { groupSourcesByFoundation, type SourceCard } from "../lib/content";

type Props = {
  sources: SourceCard[];
};

const { sources } = Astro.props;
const groups = groupSourcesByFoundation(sources);
const total = sources.length;
---

<figure class="source-map" aria-label="Source foundation by tradition">
  <figcaption>
    <span>Source foundation</span>
    <strong>{total} cards</strong>
  </figcaption>
  <ul class="source-count-list">
    {groups.map(({ domain, sources: cards }) => (
      <li>
        <a href={`/sources/#${domain.id}`}>
          <span>{domain.label}</span>
          <strong>{cards.length}</strong>
        </a>
      </li>
    ))}
  </ul>
</figure>
