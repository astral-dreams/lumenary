---
import { formatLabel, groupBy, type SourceCard } from "../lib/content";

type Props = {
  sources: SourceCard[];
};

const { sources } = Astro.props;
const sourceDomains = [
  {
    aliases: ["advaita", "vedanta", "hindu", "upanishad", "mandukya", "gaudapada"],
    label: "Advaita",
  },
  {
    aliases: ["buddh", "madhyamaka", "mahayana", "yogacara", "zen", "dogen"],
    label: "Buddhism",
  },
  {
    aliases: ["dao", "tao", "zhuangzi"],
    label: "Daoism",
  },
  {
    aliases: ["neoplat", "plotinus", "proclus"],
    label: "Neoplatonism",
  },
  {
    aliases: ["sufi", "ibn", "islamic"],
    label: "Sufism",
  },
  {
    aliases: ["consciousness", "cognitive", "computational", "neuroscience", "iit", "phenomenology"],
    label: "Consciousness",
  },
  {
    aliases: ["physics", "time", "matter", "quantum", "gravity", "cosmology", "particle", "energy"],
    label: "Time & Matter",
  },
  {
    aliases: ["project", "method", "lumenary"],
    label: "Method",
  },
];

function sourceDomain(source: SourceCard): string {
  const text = `${source.tradition} ${source.title}`.toLowerCase();
  return sourceDomains.find((domain) => domain.aliases.some((alias) => text.includes(alias)))?.label || "Other";
}

const groups = groupBy(sources, sourceDomain);
const max = Math.max(...groups.map(([, cards]) => cards.length), 1);
const total = sources.length;
---

<figure class="source-map" aria-label="Source foundation by tradition">
  <figcaption>
    <span>Source foundation</span>
    <strong>{total} cards</strong>
  </figcaption>
  <div class="source-map-grid">
    {groups.map(([tradition, cards], index) => (
      <a
        class={`source-row source-node-${index % 6}`}
        href="/sources/"
        style={`--bar-width:${Math.max(8, Math.round((cards.length / max) * 100))}%`}
      >
        <small>{formatLabel(tradition)}</small>
        <span class="source-track" aria-hidden="true">
          <span class="source-fill"></span>
        </span>
        <strong>{cards.length}</strong>
      </a>
    ))}
  </div>
</figure>
