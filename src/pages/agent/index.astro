---
import BaseLayout from "../../layouts/BaseLayout.astro";

const description =
  "The Lumenary agent documentation now lives inside the Research Method page, where the method and runtime are shown together.";
---

<BaseLayout title="Agent Moved" description={description} canonicalPath="/research/" noindex={true}>
  <section class="page-band">
    <p class="eyebrow">Agent</p>
    <h1>The Agent Now Lives Inside Method</h1>
    <p class="lead">
      The runtime details, operating loop, scheduler, providers, and storage model have been merged
      into the Research Method page so the process and machinery can be read together.
    </p>
    <div class="hero-actions">
      <a class="button button-primary" href="/research/#agent">Open the agent section</a>
      <a class="button" href="/frontiers/">See live frontiers</a>
    </div>
  </section>
</BaseLayout>
