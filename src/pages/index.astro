---
import SourceMap from "../components/SourceMap.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatLabel,
  getConvergenceNotes,
  getDailyPosts,
  getIdeas,
  getSources,
  researchStats,
  topIdeas,
} from "../lib/content";
import { faqSchema, webPageSchema } from "../lib/seo";

const dailyPosts = getDailyPosts();
const ideas = getIdeas();
const sources = getSources();
const convergences = getConvergenceNotes();
const stats = researchStats();
const latestDaily = dailyPosts[0];
const featuredIdeas = topIdeas(4);
const latestIdeas = ideas.slice(0, 4);
const homeDescription =
  "The Lumenary is a recursive AI research lab publishing original findings on spirituality, philosophy, consciousness science, and the physics of time and matter.";
const homeFaq = [
  {
    question: "What is The Lumenary?",
    answer:
      "The Lumenary is a public research project that uses a local AI research loop to study spiritual traditions, philosophy, consciousness science, and physics, then publish original observations.",
  },
  {
    question: "What does The Lumenary publish?",
    answer:
      "It publishes findings, concise insights, a living map of concepts and traditions, source-grounded research notes, and daily Journal reflections.",
  },
  {
    question: "Are The Lumenary findings final claims?",
    answer:
      "No. Findings carry epistemic labels, critique, scores, and promotion status so readers can distinguish drafts from promoted public claims.",
  },
];
const homeJsonLd = [
  webPageSchema({
    name: "The Lumenary",
    path: "/",
    description: homeDescription,
    mainEntity: {
      "@type": "ResearchProject",
      name: "The Lumenary",
      description: homeDescription,
      about: [
        "spirituality",
        "comparative philosophy",
        "consciousness science",
        "physics of time",
        "recursive AI research",
      ],
    },
  }),
  faqSchema(homeFaq),
];
---

<BaseLayout title="The Lumenary" description={homeDescription} jsonLd={homeJsonLd}>
  <section class="hero-band">
    <div class="hero-copy">
      <p class="eyebrow">Recursive, self-improving research</p>
      <h1>The Lumenary</h1>
      <p class="lead">
        A public record of original observations from a local research loop studying contemplative traditions,
        philosophy, consciousness science, and the physics of time and matter.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button button-primary" href={latestDaily ? `/daily/${latestDaily.slug}/` : "/daily/"}>
          Latest daily note
        </a>
        <a class="button" href="/findings/">Browse findings</a>
      </div>
      <div class="hero-proof" aria-label="Research foundation">
        <span>{stats.ideas} idea records</span>
        <span>{stats.sources} source cards</span>
        <span>{stats.publicClaims} public claims</span>
      </div>
    </div>

    <div class="hero-panel hero-panel-source" aria-label="Source foundation">
      <SourceMap sources={sources} />
    </div>
  </section>

  <section class="stat-band" aria-label="Research counts">
    <div><strong>{stats.ideas}</strong><span>ideas</span></div>
    <div><strong>{stats.sources}</strong><span>source cards</span></div>
    <div><strong>{stats.codex}</strong><span>Codex observations</span></div>
    <div><strong>{stats.claude}</strong><span>Claude observations</span></div>
    <div><strong>{stats.labels}</strong><span>epistemic labels</span></div>
  </section>

  <section class="content-section">
    <div class="answer-panel">
      <h2>What Is The Lumenary?</h2>
      <p>
        The Lumenary is a public recursive research lab that studies wisdom traditions, philosophy,
        consciousness science, and the physics of time and matter to generate original, source-grounded ideas.
      </p>
      <div class="answer-grid">
        {homeFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Highest signal</p>
      <h2>Promoted Public Claims</h2>
    </div>
    <div class="item-grid">
      {featuredIdeas.map((idea) => (
        <article class="item-card">
          <div class="meta-row">
            <span>{idea.agent}</span>
            <span>{formatLabel(idea.idea_type)}</span>
            <span>{idea.promotion.label}</span>
            <span>{idea.date}</span>
          </div>
          <h3><a href={`/findings/${idea.slug}/`}>{idea.title}</a></h3>
          <p>{idea.excerpt}</p>
          <div class="label-row">
            {idea.epistemic_labels.slice(0, 3).map((label) => <span>{formatLabel(label)}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section split-section">
    <div>
      <div class="section-heading">
        <p class="eyebrow">Newest artifacts</p>
        <h2>Latest Observations</h2>
      </div>
      <div class="compact-list">
        {latestIdeas.map((idea) => (
          <a href={`/findings/${idea.slug}/`}>
            <span>{idea.date}</span>
            <strong>{idea.title}</strong>
          </a>
        ))}
      </div>
    </div>
    <div>
      <div class="section-heading">
        <p class="eyebrow">Cross-agent work</p>
        <h2>Convergences</h2>
      </div>
      <div class="compact-list">
        {convergences.slice(0, 3).map((note) => (
          <a href={`/convergences/${note.slug}/`}>
            <span>{note.path}</span>
            <strong>{note.title}</strong>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
