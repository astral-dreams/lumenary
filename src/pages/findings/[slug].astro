---
import ScoreBars from "../../components/ScoreBars.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatLabel, getDialoguesForIdea, getIdeas } from "../../lib/content";
import { articleSchema, cleanDescription, faqSchema, type BreadcrumbItem } from "../../lib/seo";

export function getStaticPaths() {
  return getIdeas().map((idea) => ({
    params: { slug: idea.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const allIdeas = getIdeas();
const description = cleanDescription(idea.plainSummary || idea.atAGlance || idea.excerpt);
const audit = idea.originalityAudit;
const dialoguesForFinding = getDialoguesForIdea(idea.idea_id);
const nearNeighbors = audit?.near_neighbors?.slice(0, 3) || [];
const firstPrediction = audit?.falsifiable_predictions?.[0] || null;
const practitionerTest = audit?.practitioner_test || null;
const crossDomain = audit?.cross_domain_prediction || null;
const findingFaq = [
  {
    question: `What is the main idea of ${idea.title}?`,
    answer: idea.atAGlance || idea.plainSummary,
  },
  {
    question: "Is this finding a public claim?",
    answer: idea.promotion.publicClaim
      ? `Yes. It is promoted as ${idea.promotion.label}, while still carrying critique and source notes.`
      : `No. It is currently ${idea.promotion.label} and should be read as a draft research artifact under critique.`,
  },
  {
    question: "How does The Lumenary evaluate this finding?",
    answer: audit
      ? `The Lumenary evaluates this finding with scores, critique, promotion rules, and an originality audit that currently marks it as ${audit.label} with ${audit.confidenceLabel} confidence.`
      : "The Lumenary evaluates findings with source reliability, counterargument quality, publishability, novelty, coherence, generativity, explicit epistemic labels, and an originality audit.",
  },
];
const relatedIdeas = allIdeas
  .filter((candidate) => candidate.idea_id !== idea.idea_id)
  .map((candidate) => ({
    ...candidate,
    overlap: candidate.traditionTags.filter((tag) => idea.traditionTags.includes(tag)).length,
  }))
  .filter((candidate) => candidate.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.insightScore - a.insightScore)
  .slice(0, 3);
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Findings", path: "/findings/" },
  { name: idea.title, path: `/findings/${idea.slug}/` },
];
const findingJsonLd = [
  articleSchema({
    headline: idea.title,
    description,
    path: `/findings/${idea.slug}/`,
    datePublished: idea.created_at,
    dateModified: idea.updatedAt,
    authorName: idea.agent === "claude" ? "Claude Code for The Lumenary" : "Codex for The Lumenary",
    articleSection: formatLabel(idea.idea_type),
    keywords: [...idea.traditionTags, ...idea.epistemic_labels, idea.promotion.label],
    citations: idea.source_basis.slice(0, 10),
    relatedLinks: relatedIdeas.map((related) => `/findings/${related.slug}/`),
  }),
  faqSchema(findingFaq),
];
---

<BaseLayout title={idea.title} description={description} ogType="article" jsonLd={findingJsonLd} breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <article class="article-page">
    <header class="article-header">
      <p class="eyebrow">{idea.agent} / {formatLabel(idea.idea_type)} / {idea.promotion.label}</p>
      <h1>{idea.title}</h1>
      <p class="lead">{idea.insight}</p>
      <div class="label-row">
        {idea.epistemic_labels.map((label) => <span>{formatLabel(label)}</span>)}
      </div>
    </header>

    <section class="plain-summary">
      <p class="eyebrow">At a glance</p>
      <p>{idea.atAGlance}</p>
      <ul class="glance-points" aria-label="Key points">
        {idea.atAGlancePoints.map((point) => <li>{point}</li>)}
      </ul>
    </section>

    {dialoguesForFinding.length > 0 && (
      <section class="article-section answer-panel">
        <p class="eyebrow">Dialogue pressure</p>
        <h2>Debated In Dialogues</h2>
        <div class="compact-list">
          {dialoguesForFinding.map((dialogue) => (
            <a href={`/dialogues/${dialogue.slug}/`}>
              <span>{dialogue.outcomeLabel} / {dialogue.date}</span>
              <strong>{dialogue.title}</strong>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="article-section originality-audit-panel">
      <p class="eyebrow">Originality audit</p>
      {audit ? (
        <>
          <div class="audit-stat-grid">
            <div>
              <span>Status</span>
              <strong>{audit.label}</strong>
            </div>
            <div>
              <span>Confidence</span>
              <strong>{audit.confidenceLabel}</strong>
            </div>
            <div>
              <span>Novelty score</span>
              <strong>{Number(audit.recommended_scores?.novelty || idea.scores.novelty || 0).toFixed(2)}</strong>
            </div>
          </div>
          <p class="audit-summary">{audit.summary}</p>

          <div class="audit-detail-grid">
            <div class="audit-detail">
              <h2>Closest Prior Art</h2>
              {nearNeighbors.length > 0 ? (
                <ul class="clean-list audit-list">
                  {nearNeighbors.map((neighbor) => (
                    <li>
                      <strong>{neighbor.source}</strong>
                      <span>Overlap: {neighbor.overlap}</span>
                      <span>Difference: {neighbor.difference}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p>No close near-neighbor was recorded in this audit.</p>
              )}
            </div>

            <div class="audit-detail">
              <h2>What Could Break It</h2>
              {audit.anomaly_probe?.anomaly_candidate && (
                <p><strong>Anomaly:</strong> {audit.anomaly_probe.anomaly_candidate}</p>
              )}
              {firstPrediction && (
                <p>
                  <strong>Test:</strong> If the model is right, {firstPrediction.expected_observation}
                  {" "}It weakens if {firstPrediction.would_weaken_or_falsify}
                </p>
              )}
            </div>

            <div class="audit-detail">
              <h2>Practitioner Test</h2>
              {practitionerTest?.questions?.length ? (
                <ul class="clean-list">
                  {practitionerTest.questions.slice(0, 3).map((question) => <li>{question}</li>)}
                </ul>
              ) : (
                <p>No practitioner questions were recorded in this audit.</p>
              )}
            </div>

            <div class="audit-detail">
              <h2>Cross-Domain Test</h2>
              {crossDomain?.prediction ? (
                <p>{crossDomain.prediction}</p>
              ) : (
                <p>No cross-domain prediction was recorded in this audit.</p>
              )}
            </div>
          </div>
        </>
      ) : (
        <p class="audit-summary">
          This finding does not have an originality audit yet. Treat it as a draft until prior art,
          anomaly tests, practitioner tests, and cross-domain predictions are added.
        </p>
      )}
    </section>

    <section class="article-section answer-panel">
      <h2>Common Questions</h2>
      <div class="answer-grid">
        {findingFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    {idea.articleHtml && (
      <section class="article-section prose public-article" set:html={idea.articleHtml} />
    )}

    <section class="article-section">
      <h2>Original Claim</h2>
      <div class="prose compact-prose" set:html={idea.originalClaimHtml} />
    </section>

    <section class="article-section">
      <h2>Why It Might Be New</h2>
      <div class="prose compact-prose" set:html={idea.whyItMightBeNewHtml} />
    </section>

    <section class="article-section">
      <h2>Critique</h2>
      <div class="prose compact-prose" set:html={idea.critiqueHtml} />
    </section>

    <section class="article-section">
      <h2>Promotion Gate</h2>
      <p>
        Status: {idea.promotion.publicClaim ? "Promoted public claim" : "Not promoted as a public claim"}.
        Source reliability, counterargument quality, and publishability determine whether this can be featured.
      </p>
      <ul class="clean-list">
        {idea.promotion.reasons.map((reason) => <li>{reason}</li>)}
      </ul>
    </section>

    <section class="article-section">
      <h2>Scores</h2>
      <ScoreBars scores={idea.scores} />
    </section>

    <section class="article-section">
      <h2>Source Basis</h2>
      <ul class="clean-list">
        {idea.source_basis.map((source) => <li>{source}</li>)}
      </ul>
    </section>

    {relatedIdeas.length > 0 && (
      <section class="article-section">
        <h2>Related Findings</h2>
        <div class="compact-list">
          {relatedIdeas.map((related) => (
            <a href={`/findings/${related.slug}/`}>
              <span>{related.date}</span>
              <strong>{related.title}</strong>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="article-section">
      <h2>Next Directions</h2>
      <ul class="clean-list">
        {idea.next_research_directions.map((direction) => <li>{direction}</li>)}
      </ul>
    </section>
  </article>
</BaseLayout>
