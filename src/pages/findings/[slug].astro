---
import ScoreBars from "../../components/ScoreBars.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatLabel, getIdeas } from "../../lib/content";

export function getStaticPaths() {
  return getIdeas().map((idea) => ({
    params: { slug: idea.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const description = idea.atAGlance || idea.plainSummary || idea.excerpt;
const findingFaq = [
  {
    question: `What is the main idea of ${idea.title}?`,
    answer: idea.atAGlance || idea.plainSummary,
  },
  {
    question: "Is this finding a public claim?",
    answer: idea.promotion.publicClaim
      ? `Yes. It is promoted as ${idea.promotion.label}, while still carrying critique and source notes.`
      : `No. It is currently ${idea.promotion.label} and should be read as a draft research artifact under critique.`,
  },
  {
    question: "How does The Lumenary evaluate this finding?",
    answer:
      "The Lumenary evaluates findings with source reliability, counterargument quality, publishability, novelty, coherence, generativity, and explicit epistemic labels.",
  },
];
const findingJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: idea.title,
    description,
    url: `https://thelumenary.org/findings/${idea.slug}/`,
    datePublished: idea.created_at,
    dateModified: idea.created_at,
    author: {
      "@type": "Organization",
      name: idea.agent === "claude" ? "Claude Code for The Lumenary" : "Codex for The Lumenary",
    },
    publisher: {
      "@type": "Organization",
      name: "The Lumenary",
      url: "https://thelumenary.org/",
    },
    articleSection: formatLabel(idea.idea_type),
    keywords: [...idea.traditionTags, ...idea.epistemic_labels, idea.promotion.label].join(", "),
    mainEntityOfPage: `https://thelumenary.org/findings/${idea.slug}/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "The Lumenary",
        item: "https://thelumenary.org/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Findings",
        item: "https://thelumenary.org/findings/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: idea.title,
        item: `https://thelumenary.org/findings/${idea.slug}/`,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: findingFaq.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title={idea.title} description={description} ogType="article" jsonLd={findingJsonLd}>
  <article class="article-page">
    <header class="article-header">
      <p class="eyebrow">{idea.agent} / {formatLabel(idea.idea_type)} / {idea.promotion.label}</p>
      <h1>{idea.title}</h1>
      <p class="lead">{idea.insight}</p>
      <div class="label-row">
        {idea.epistemic_labels.map((label) => <span>{formatLabel(label)}</span>)}
      </div>
    </header>

    <section class="plain-summary">
      <p class="eyebrow">At a glance</p>
      <p>{idea.atAGlance}</p>
    </section>

    <section class="article-section answer-panel">
      <p class="eyebrow">Direct answer</p>
      <h2>Common Questions</h2>
      <div class="answer-grid">
        {findingFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    {idea.articleHtml && (
      <section class="article-section prose public-article" set:html={idea.articleHtml} />
    )}

    <section class="article-section">
      <h2>Original Claim</h2>
      <div class="prose compact-prose" set:html={idea.originalClaimHtml} />
    </section>

    <section class="article-section">
      <h2>Why It Might Be New</h2>
      <div class="prose compact-prose" set:html={idea.whyItMightBeNewHtml} />
    </section>

    <section class="article-section">
      <h2>Critique</h2>
      <div class="prose compact-prose" set:html={idea.critiqueHtml} />
    </section>

    <section class="article-section">
      <h2>Promotion Gate</h2>
      <p>
        Status: {idea.promotion.publicClaim ? "Promoted public claim" : "Not promoted as a public claim"}.
        Source reliability, counterargument quality, and publishability determine whether this can be featured.
      </p>
      <ul class="clean-list">
        {idea.promotion.reasons.map((reason) => <li>{reason}</li>)}
      </ul>
    </section>

    <section class="article-section">
      <h2>Scores</h2>
      <ScoreBars scores={idea.scores} />
    </section>

    <section class="article-section">
      <h2>Source Basis</h2>
      <ul class="clean-list">
        {idea.source_basis.map((source) => <li>{source}</li>)}
      </ul>
    </section>

    <section class="article-section">
      <h2>Next Directions</h2>
      <ul class="clean-list">
        {idea.next_research_directions.map((direction) => <li>{direction}</li>)}
      </ul>
    </section>
  </article>
</BaseLayout>
