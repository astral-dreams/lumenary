---
import ScoreBars from "../../components/ScoreBars.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatLabel, getIdeas } from "../../lib/content";

export function getStaticPaths() {
  return getIdeas().map((idea) => ({
    params: { slug: idea.slug },
    props: { idea },
  }));
}

const { idea } = Astro.props;
---

<BaseLayout title={idea.title} description={idea.excerpt}>
  <article class="article-page">
    <header class="article-header">
      <p class="eyebrow">{idea.agent} / {formatLabel(idea.idea_type)} / {idea.promotion.label}</p>
      <h1>{idea.title}</h1>
      <p class="lead">{idea.insight}</p>
      <div class="label-row">
        {idea.epistemic_labels.map((label) => <span>{formatLabel(label)}</span>)}
      </div>
    </header>

    <section class="plain-summary">
      <p class="eyebrow">At a glance</p>
      <p>{idea.plainSummary}</p>
    </section>

    {idea.articleHtml && (
      <section class="article-section prose public-article" set:html={idea.articleHtml} />
    )}

    <section class="article-section">
      <h2>Original Claim</h2>
      <div class="prose compact-prose" set:html={idea.originalClaimHtml} />
    </section>

    <section class="article-section">
      <h2>Why It Might Be New</h2>
      <div class="prose compact-prose" set:html={idea.whyItMightBeNewHtml} />
    </section>

    <section class="article-section">
      <h2>Critique</h2>
      <div class="prose compact-prose" set:html={idea.critiqueHtml} />
    </section>

    <section class="article-section">
      <h2>Promotion Gate</h2>
      <p>
        Status: {idea.promotion.publicClaim ? "Promoted public claim" : "Not promoted as a public claim"}.
        Source reliability, counterargument quality, and publishability determine whether this can be featured.
      </p>
      <ul class="clean-list">
        {idea.promotion.reasons.map((reason) => <li>{reason}</li>)}
      </ul>
    </section>

    <section class="article-section">
      <h2>Scores</h2>
      <ScoreBars scores={idea.scores} />
    </section>

    <section class="article-section">
      <h2>Source Basis</h2>
      <ul class="clean-list">
        {idea.source_basis.map((source) => <li>{source}</li>)}
      </ul>
    </section>

    <section class="article-section">
      <h2>Next Directions</h2>
      <ul class="clean-list">
        {idea.next_research_directions.map((direction) => <li>{direction}</li>)}
      </ul>
    </section>
  </article>
</BaseLayout>
