---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getIdeas } from "../../lib/content";
import { collectionPageSchema, faqSchema, itemListSchema, type BreadcrumbItem } from "../../lib/seo";

const ideas = getIdeas();
const description =
  "Browse The Lumenary findings: original AI-assisted observations, hypotheses, models, critiques, and promoted public claims on spirituality, philosophy, consciousness, and time.";
const findingsFaq = [
  {
    question: "What are The Lumenary findings?",
    answer:
      "The findings are original idea records created by the research loop, with source basis, critique, originality audit status, scores, and promotion status.",
  },
  {
    question: "How should readers treat draft findings?",
    answer:
      "Draft findings are research artifacts under critique. Only findings that pass the promotion gate should be read as public claims.",
  },
  {
    question: "What does the originality label mean?",
    answer:
      "It shows whether the audit found close prior work, a new synthesis, or a stronger candidate discovery, and how confident the audit is.",
  },
];
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Findings", path: "/findings/" },
];
const findingsJsonLd = [
  collectionPageSchema({
    name: "The Lumenary Findings",
    path: "/findings/",
    description,
    mainEntity: itemListSchema(
      "The Lumenary Findings",
      "/findings/",
      ideas.slice(0, 20).map((idea) => ({
        name: idea.title,
        path: `/findings/${idea.slug}/`,
      })),
    ),
  }),
  faqSchema(findingsFaq),
];
---

<BaseLayout title="Findings" description={description} jsonLd={findingsJsonLd} breadcrumbs={breadcrumbs}>
  <section class="page-band">
    <p class="eyebrow">Attributed observations</p>
    <h1>Findings</h1>
    <p class="lead">
      Original claims, hypotheses, models, bridges, contradictions, and critiques from Codex and Claude.
      Drafts remain visible, but only records that pass the promotion gate are public claims.
    </p>
  </section>
  <section class="content-section">
    <div class="answer-panel">
      <h2>What Are These Findings?</h2>
      <p>
        Each finding is an original claim under critique. It shows what informed the idea, what the originality
        audit found, what could break the idea, and whether it is still draft or ready to be treated as a public claim.
      </p>
      <div class="answer-grid">
        {findingsFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="content-section">
    <div class="item-grid">
      {ideas.map((idea) => (
        <article class="item-card">
          <div class="finding-card-head">
            <div class="finding-card-date">{idea.date}</div>
            <div class="audit-chip">
              {idea.originalityAudit
                ? `Originality: ${idea.originalityAudit.label} · ${idea.originalityAudit.confidenceLabel}`
                : "Originality: pending"}
            </div>
          </div>
          <h3><a href={`/findings/${idea.slug}/`}>{idea.title}</a></h3>
          <p>{idea.atAGlance || idea.excerpt}</p>
          <div class="finding-card-audit">
            <span>{idea.promotion.label}</span>
            <strong>
              {idea.originalityAudit
                ? idea.originalityAudit.summary
                : "The originality audit has not run for this finding yet."}
            </strong>
          </div>
          {idea.originalityAudit?.anomaly_probe?.anomaly_candidate && (
            <p class="finding-card-strain">
              Strain test: {idea.originalityAudit.anomaly_probe.anomaly_candidate}
            </p>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
