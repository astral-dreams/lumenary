---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatLabel, getSources, groupSourcesByFoundation } from "../../lib/content";
import { collectionPageSchema, datasetSchema, faqSchema, type BreadcrumbItem } from "../../lib/seo";

const sources = getSources();
const groups = groupSourcesByFoundation(sources);
const modernHumanCondition = groups.find(({ domain }) => domain.id === "modern-human-condition");
const description =
  "Source cards behind The Lumenary research corpus, covering spiritual traditions, modern human condition research, consciousness science, and physics of time and matter.";
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Sources", path: "/sources/" },
];
const sourcesFaq = [
  {
    question: "What are source cards?",
    answer:
      "Source cards are the texts, papers, references, and method notes that ground The Lumenary's findings.",
  },
  {
    question: "How do sources constrain findings?",
    answer:
      "Sources keep the system from treating analogy as proof by making each finding show what informed the claim.",
  },
  {
    question: "Why include modern human-condition sources?",
    answer:
      "They keep teachings and practices tied to recognizable human problems: loneliness, burnout, addiction, anxiety, grief, meaning loss, and the search for belonging.",
  },
];
const sourcesJsonLd = [
  collectionPageSchema({
    name: "The Lumenary Source Cards",
    path: "/sources/",
    description,
    mainEntity: datasetSchema({
      name: "The Lumenary Source Corpus",
      path: "/sources/",
      description,
      keywords: groups.map(({ domain }) => domain.label),
    }),
  }),
  faqSchema(sourcesFaq),
];
---

<BaseLayout title="Sources" description={description} jsonLd={sourcesJsonLd} breadcrumbs={breadcrumbs}>
  <section class="page-band">
    <p class="eyebrow">Grounding corpus</p>
    <h1>Source Cards</h1>
    <p class="lead">The public source foundation behind Lumenary's spiritual, philosophical, human-condition, consciousness, and physics research.</p>
  </section>
  {modernHumanCondition && (
    <section class="content-section">
      <div class="answer-panel human-condition-source-panel">
        <p class="eyebrow">Modern human condition</p>
        <h2>The wound a teaching must answer</h2>
        <p>
          These sources keep The Lumenary from making beautiful ideas that solve nothing. They ground the work in
          modern loneliness, burnout, addiction, stress, digital comparison, mental distress, and the loss of shared
          meaning.
        </p>
        <a class="button" href="#modern-human-condition">Read the human-condition source cards</a>
      </div>
    </section>
  )}
  <section class="content-section">
    <div class="answer-panel">
      <h2>What Are Source Cards?</h2>
      <p>
        Source cards are the grounding layer behind The Lumenary. They show the traditions, texts, papers,
        and references that constrain the research before an idea can become a public claim.
      </p>
      <div class="answer-grid">
        {sourcesFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="content-section">
    <nav class="source-index-list" aria-label="Source foundation links">
      {groups.map(({ domain, sources }) => (
        <a href={`#${domain.id}`}>
          <span>{domain.label}</span>
          <strong>{sources.length}</strong>
        </a>
      ))}
    </nav>
  </section>
  <section class="content-section source-groups">
    {groups.map(({ domain, sources }) => (
      <section id={domain.id} class="source-group">
        <div class="section-heading">
          <p class="eyebrow">{sources.length} {sources.length === 1 ? "card" : "cards"}</p>
          <h2>{domain.label}</h2>
        </div>
        <div class="source-list">
          {sources.map((source) => (
            <article id={source.source_id} class="source-card">
              <div class="meta-row">
                <span>{formatLabel(source.source_type)}</span>
                <span>{source.source_id}</span>
              </div>
              <h3>{source.title}</h3>
              <p>{source.notes}</p>
              <div class="source-card-actions">
                <a href={`#${source.source_id}`}>Link to card</a>
                {source.url && <a href={source.url} rel="noreferrer">Open source</a>}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
