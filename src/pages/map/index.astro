---
import LivingMap from "../../components/LivingMap.astro";
import LumenaryMindMap from "../../components/LumenaryMindMap.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getConceptGraph,
  getConvergenceNotes,
  getGrowthRecords,
  getIdeas,
  getSources,
  researchStats,
} from "../../lib/content";
import { collectionPageSchema, datasetSchema, faqSchema, type BreadcrumbItem } from "../../lib/seo";

const graph = getConceptGraph();
const sources = getSources();
const ideas = getIdeas();
const convergences = getConvergenceNotes();
const growthRecords = getGrowthRecords();
const stats = researchStats();
const description =
  "The Lumenary Living Map updates daily at 6pm local time with maps of knowledge, method, sources, concepts, and findings.";
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Living Map", path: "/map/" },
];
const mapFaq = [
  {
    question: "What is The Lumenary's Knowledge Map?",
    answer:
      "It shows the knowledge that influences The Lumenary, drawn from Growth records, Findings, and source-backed idea records.",
  },
  {
    question: "What is The Lumenary's Method Map?",
    answer:
      "It shows the methods that influence The Lumenary's way of seeing, questioning, criticizing, and returning to sources.",
  },
  {
    question: "What is the Research Map?",
    answer:
      "It is the living knowledge graph for the research corpus: sources, traditions, concepts, methods, promoted claims, contradictions, and findings.",
  },
  {
    question: "How often are the living maps updated?",
    answer:
      "A launchd job refreshes the Map page every day at 6pm local time by rebuilding and deploying all three SVG graphs.",
  },
  {
    question: "What data updates the maps?",
    answer:
      "The maps are rebuilt from Growth records, Findings, idea records, the concept graph, source index, promotion gates, and convergence notes.",
  },
  {
    question: "Why do the maps matter?",
    answer:
      "They reveal the knowledge, methods, sources, and tensions that influence the system's work.",
  },
];
const mapJsonLd = [
  collectionPageSchema({
    name: "The Lumenary Map",
    path: "/map/",
    description,
    about: [
      "comparative philosophy",
      "spiritual traditions",
      "consciousness science",
      "physics of time and matter",
      "knowledge graph",
    ],
    mainEntity: datasetSchema({
      name: "The Lumenary Living Map",
      path: "/map/",
      description:
        "A living map rebuilt daily from knowledge records, method records, sources, concept relationships, promotion status, and convergence notes.",
      variableMeasured: [
        "knowledge influence",
        "method influence",
        "concept nodes",
        "relationship edges",
        "source cards",
        "idea records",
        "public claims",
      ],
    }),
  }),
  faqSchema(mapFaq),
];
---

<BaseLayout title="Living Map" description={description} jsonLd={mapJsonLd} breadcrumbs={breadcrumbs}>
  <section class="page-band">
    <p class="eyebrow">Living atlas</p>
    <h1>Living Map</h1>
    <p class="lead">
      Maps of The Lumenary's growing mind: what it knows, how it learns, and how the research corpus connects.
      They refresh every day at 6pm local time.
    </p>
  </section>

  <section class="map-section">
    <div class="map-section-heading">
      <p class="eyebrow">Mind of knowledge</p>
      <h2>The Lumenary's Knowledge Map</h2>
      <p>
        A living graph of the knowledge influencing the research loop, drawn from Growth records, linked Findings, and source-backed idea records.
      </p>
    </div>
    <LumenaryMindMap mode="knowledge" records={growthRecords} ideas={ideas} />
  </section>

  <section class="map-section">
    <div class="map-section-heading">
      <p class="eyebrow">Mind of method</p>
      <h2>The Lumenary's Method Map</h2>
      <p>
        A living graph of the methods influencing how the research loop observes, questions, criticizes, and returns to the sources.
      </p>
    </div>
    <LumenaryMindMap mode="method" records={growthRecords} ideas={ideas} />
  </section>

  <section class="map-section map-section-last">
    <div class="map-section-heading">
      <p class="eyebrow">Research graph</p>
      <h2>Research Map</h2>
      <p>
        A living graph of the sources influencing the research map, plus concepts, methods, promoted claims, contradictions, and findings.
      </p>
    </div>
    <LivingMap graph={graph} sources={sources} ideas={ideas} convergences={convergences} />
  </section>

  <section class="stat-band map-stat-band" aria-label="Map counts">
    <div><strong>{graph.nodes.length}</strong><span>concept nodes</span></div>
    <div><strong>{graph.edges.length}</strong><span>relationship edges</span></div>
    <div><strong>{stats.sources}</strong><span>source cards</span></div>
    <div><strong>{stats.ideas}</strong><span>idea records</span></div>
    <div><strong>{stats.publicClaims}</strong><span>public claims</span></div>
  </section>

  <section class="content-section">
    <div class="answer-panel">
      <h2>What Do The Lumenary Maps Show?</h2>
      <p>
        The Lumenary's three living maps are rebuilt every day at 6pm local time from Growth records, Findings,
        source cards, concept relationships, convergence notes, and promotion gates. The first map shows the knowledge
        influencing The Lumenary. The second map shows the methods influencing its way of seeing. The third map shows the
        sources influencing the research map, alongside concepts, methods, and findings.
      </p>
      <div class="answer-grid">
        {mapFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
