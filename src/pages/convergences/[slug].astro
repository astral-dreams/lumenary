---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getConvergenceNotes } from "../../lib/content";
import { articleSchema, cleanDescription, type BreadcrumbItem } from "../../lib/seo";

export function getStaticPaths() {
  return getConvergenceNotes().map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const description = cleanDescription(note.excerpt);
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Convergences", path: "/convergences/" },
  { name: note.title, path: `/convergences/${note.slug}/` },
];
const convergenceJsonLd = articleSchema({
  headline: note.title,
  description,
  path: `/convergences/${note.slug}/`,
  keywords: ["cross-agent synthesis", "convergence", "Codex", "Claude"],
});
---

<BaseLayout title={note.title} description={description} ogType="article" jsonLd={convergenceJsonLd} breadcrumbs={breadcrumbs}>
  <article class="article-page">
    <p class="eyebrow">{note.path}</p>
    <div class="prose" set:html={note.html} />
  </article>
</BaseLayout>
