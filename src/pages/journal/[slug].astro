---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getJournalPosts } from "../../lib/content";
import { articleSchema, cleanDescription, type BreadcrumbItem } from "../../lib/seo";

export function getStaticPaths() {
  return getJournalPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const description = cleanDescription(post.excerpt);
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Journal", path: "/journal/" },
  { name: post.title, path: `/journal/${post.slug}/` },
];
const jsonLd = articleSchema({
  type: "BlogPosting",
  headline: post.title,
  description,
  path: `/journal/${post.slug}/`,
  datePublished: post.date,
  dateModified: new Date(post.updated).toISOString(),
  keywords: ["journal", "recursive research", "spirituality", "consciousness"],
});
---

<BaseLayout title={post.title} description={description} ogType="article" jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <article class="article-page journal-entry">
    <p class="eyebrow">{post.date}</p>
    <div class="prose" set:html={post.html} />
  </article>
</BaseLayout>
