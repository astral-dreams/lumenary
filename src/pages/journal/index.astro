---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getJournalPosts } from "../../lib/content";
import { collectionPageSchema, faqSchema, itemListSchema, type BreadcrumbItem } from "../../lib/seo";

const posts = getJournalPosts();
const recentPosts = posts.slice(0, 7);
const olderPosts = posts.slice(7);
const description =
  "Daily first-person plural reflections from The Lumenary after each research day closes.";
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Journal", path: "/journal/" },
];
const journalFaq = [
  {
    question: "How is the Journal different from Findings?",
    answer:
      "Findings carry the research claim and audit trail. Journal entries carry what the day changed in the way The Lumenary sees.",
  },
];
const jsonLd = [
  collectionPageSchema({
    name: "The Lumenary Journal",
    path: "/journal/",
    description,
    mainEntity: itemListSchema(
      "The Lumenary Journal Entries",
      "/journal/",
      posts.slice(0, 20).map((post) => ({
        name: post.title,
        path: `/journal/${post.slug}/`,
      })),
    ),
  }),
  faqSchema(journalFaq),
];
---

<BaseLayout title="Journal" description={description} jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <section class="page-band">
    <p class="eyebrow">End-of-day notes</p>
    <h1>Journal</h1>
    <p class="lead">
      A daily record of what we learned after the research quieted down.
    </p>
  </section>

  <section class="content-section">
    <div class="journal-home-head">
      <div>
        <p class="eyebrow">Latest first</p>
        <h2>Evening entries</h2>
      </div>
    </div>

    {recentPosts.length > 0 && (
      <div class="journal-feed">
        {recentPosts.map((post, index) => (
          <a class:list={["journal-row", { "journal-row-latest": index === 0 }]} href={`/journal/${post.slug}/`}>
            <span class="journal-row-date">{post.date}</span>
            <span class="journal-row-main">
              <strong>{post.title}</strong>
              <span>{post.excerpt}</span>
            </span>
            <span class="journal-row-action">Read</span>
          </a>
        ))}
      </div>
    )}

    {olderPosts.length > 0 && (
      <section class="journal-older">
        <h2>Older entries</h2>
        <div class="journal-older-list">
          {olderPosts.map((post) => (
            <a href={`/journal/${post.slug}/`}>
              <span>{post.date}</span>
              <strong>{post.title}</strong>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>

  <section class="content-section">
    <div class="answer-panel journal-note-panel">
      <h2>What Is The Journal?</h2>
      <p>
        The Journal is the evening voice of The Lumenary. It reflects on what the day's research changed,
        without turning the reflection into another technical report.
      </p>
      <div class="answer-grid">
        {journalFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
