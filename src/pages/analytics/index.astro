---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  analyticsOverviewStats,
  gaMeasurementLabel,
  getAnalyticsSetup,
  getAeoReadiness,
  hasGaTracking,
  hasGscVerification,
} from "../../lib/analytics";

const setup = getAnalyticsSetup();
const stats = analyticsOverviewStats();
const readiness = getAeoReadiness();
const description =
  "Internal marketing analytics overview for The Lumenary, covering GA4 tracking, Search Console setup, and answer-engine tracking readiness.";

const setupCards = [
  {
    label: "GA4 Tracking",
    value: hasGaTracking() ? "Live" : "Waiting",
    detail: hasGaTracking()
      ? `Measurement ID ${gaMeasurementLabel()} is built into the site.`
      : `Set ${setup.ga4.measurement_env} in local .env or Cloudflare Pages env to load GA4 on every page.`,
  },
  {
    label: "Search Console",
    value: hasGscVerification() ? "Verifiable" : "Waiting",
    detail: hasGscVerification()
      ? "The Google verification meta tag is built into the site."
      : `Add ${setup.gsc.verification_env} for URL-prefix verification, or use DNS verification for the domain property.`,
  },
  {
    label: "AEO Tracking",
    value: "Wired",
    detail: "AI-referral landing events, llms.txt, structured data, and the starter query inventory are in place.",
  },
  {
    label: "Sitemap",
    value: "Ready",
    detail: setup.gsc.sitemap,
  },
];
---

<BaseLayout title="Analytics" description={description} noindex>
  <section class="page-band analytics-hero">
    <p class="eyebrow">Internal analytics</p>
    <h1>Marketing Analytics</h1>
    <p class="lead">
      A small control room for traffic, acquisition, and answer-engine visibility.
    </p>
    <nav class="analytics-tabs" aria-label="Analytics navigation">
      <a class="analytics-tab active" href="/analytics/">Overview</a>
      <a class="analytics-tab" href="/analytics/acquisition/">Acquisition</a>
      <a class="analytics-tab" href="/analytics/aeo/">AEO</a>
    </nav>
  </section>

  <section class="content-section">
    <div class="analytics-grid analytics-grid-four">
      {setupCards.map((card) => (
        <article class="analytics-card">
          <span>{card.label}</span>
          <strong>{card.value}</strong>
          <p>{card.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="analytics-grid analytics-grid-four">
      <article class="analytics-card">
        <span>Idea Records</span>
        <strong>{stats.ideaRecords}</strong>
        <p>Structured observations in the research corpus.</p>
      </article>
      <article class="analytics-card">
        <span>Promoted Claims</span>
        <strong>{stats.promotedClaims}</strong>
        <p>Findings that pass the public-claim gate.</p>
      </article>
      <article class="analytics-card">
        <span>Source Cards</span>
        <strong>{stats.sourceCards}</strong>
        <p>Grounding sources available to the loop.</p>
      </article>
      <article class="analytics-card">
        <span>AEO Queries</span>
        <strong>{stats.aeoQueries}</strong>
        <p>Starter questions for citation checks.</p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <div class="analytics-panel">
      <div class="section-heading">
        <p class="eyebrow">Readiness</p>
        <h2>AEO Setup Checks</h2>
      </div>
      <div class="analytics-table">
        {readiness.checks.map((check) => (
          <div class="analytics-row">
            <strong>{check.label}</strong>
            <span>{check.status}</span>
            <p>{check.notes}</p>
            <code>{check.path}</code>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
