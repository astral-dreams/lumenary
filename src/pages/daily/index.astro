---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDailyPosts } from "../../lib/content";
import { collectionPageSchema, itemListSchema, type BreadcrumbItem } from "../../lib/seo";

const posts = getDailyPosts();
const description =
  "Daily public research notes from The Lumenary, generated from promoted findings in the recursive spirituality and consciousness research loop.";
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Daily Log", path: "/daily/" },
];
const dailyJsonLd = collectionPageSchema({
  name: "The Lumenary Daily Log",
  path: "/daily/",
  description,
  mainEntity: itemListSchema(
    "The Lumenary Daily Notes",
    "/daily/",
    posts.slice(0, 20).map((post) => ({
      name: post.title,
      path: `/daily/${post.slug}/`,
    })),
  ),
});
---

<BaseLayout title="Daily Log" description={description} jsonLd={dailyJsonLd} breadcrumbs={breadcrumbs}>
  <section class="page-band">
    <p class="eyebrow">Publication log</p>
    <h1>Daily Log</h1>
    <p class="lead">Public-facing research notes generated from the strongest current findings.</p>
  </section>
  <section class="content-section">
    <div class="item-grid">
      {posts.map((post) => (
        <article class="item-card">
          <div class="meta-row"><span>{post.date}</span><span>{post.path}</span></div>
          <h3><a href={`/daily/${post.slug}/`}>{post.title}</a></h3>
          <p>{post.excerpt}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
