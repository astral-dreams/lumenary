---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDailyPosts } from "../../lib/content";

const posts = getDailyPosts();
const description =
  "Daily public research notes from The Lumenary, generated from promoted findings in the recursive spirituality and consciousness research loop.";
const dailyJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "The Lumenary Daily Log",
  url: "https://thelumenary.org/daily/",
  description,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: posts.length,
    itemListElement: posts.slice(0, 20).map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: post.title,
      url: `https://thelumenary.org/daily/${post.slug}/`,
    })),
  },
};
---

<BaseLayout title="Daily Log" description={description} jsonLd={dailyJsonLd}>
  <section class="page-band">
    <p class="eyebrow">Publication log</p>
    <h1>Daily Log</h1>
    <p class="lead">Public-facing research notes generated from the strongest current findings.</p>
  </section>
  <section class="content-section">
    <div class="item-grid">
      {posts.map((post) => (
        <article class="item-card">
          <div class="meta-row"><span>{post.date}</span><span>{post.path}</span></div>
          <h2><a href={`/daily/${post.slug}/`}>{post.title}</a></h2>
          <p>{post.excerpt}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
