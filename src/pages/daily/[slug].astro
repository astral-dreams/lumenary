---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDailyPosts } from "../../lib/content";
import { articleSchema, cleanDescription, type BreadcrumbItem } from "../../lib/seo";

export function getStaticPaths() {
  return getDailyPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const description = cleanDescription(post.excerpt);
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Daily Log", path: "/daily/" },
  { name: post.title, path: `/daily/${post.slug}/` },
];
const dailyPostJsonLd = articleSchema({
  headline: post.title,
  description,
  path: `/daily/${post.slug}/`,
  datePublished: post.date,
  dateModified: new Date(post.updated).toISOString(),
  keywords: ["daily research", "spirituality", "consciousness", "original findings"],
});
---

<BaseLayout title={post.title} description={description} ogType="article" jsonLd={dailyPostJsonLd} breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <article class="article-page">
    <p class="eyebrow">{post.date}</p>
    <div class="prose" set:html={post.html} />
  </article>
</BaseLayout>
