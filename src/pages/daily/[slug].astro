---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDailyPosts } from "../../lib/content";

export function getStaticPaths() {
  return getDailyPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const dailyPostJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.excerpt,
  url: `https://thelumenary.org/daily/${post.slug}/`,
  datePublished: post.date,
  dateModified: new Date(post.updated).toISOString(),
  author: {
    "@type": "Organization",
    name: "The Lumenary",
  },
  publisher: {
    "@type": "Organization",
    name: "The Lumenary",
    url: "https://thelumenary.org/",
  },
};
---

<BaseLayout title={post.title} description={post.excerpt} ogType="article" jsonLd={dailyPostJsonLd}>
  <article class="article-page">
    <p class="eyebrow">{post.date}</p>
    <div class="prose" set:html={post.html} />
  </article>
</BaseLayout>
