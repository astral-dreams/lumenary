---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPromotionRules } from "../../lib/content";

const promotionRules = getPromotionRules();
const promotionStages = Object.entries(promotionRules.stages);
const description =
  "The Lumenary method explains how the research loop sources material, applies practitioner thinking methods, audits originality, critiques ideas, and promotes only strong public claims.";
const methodSteps = [
  "Ground ideas in source cards and separate text, interpretation, analogy, and speculation.",
  "Close-read primary texts against each other before leaning on secondary comparisons.",
  "Use translation strain to test whether apparent cross-tradition agreement is real or forced.",
  "Apply and critique practitioner methods for observing, thinking, learning, and gaining insight.",
  "Hunt for anomalies, near-neighbors, falsifiable predictions, practitioner tests, and cross-domain tests.",
  "Score each idea for novelty, coherence, source reliability, counterargument quality, and publishability.",
  "Promote only findings that pass explicit public-claim thresholds.",
];
const methodFaq = [
  {
    question: "How does The Lumenary generate original ideas?",
    answer:
      "It compares source cards, claim units, traditions, scientific parallels, contradictions, and practitioner methods, then generates a single original idea record for critique.",
  },
  {
    question: "How does The Lumenary avoid treating analogy as proof?",
    answer:
      "Every serious idea carries epistemic labels and a critique, and scientific parallels are marked as analogical unless stronger evidence is available.",
  },
  {
    question: "What makes a finding publishable?",
    answer:
      "A finding must pass thresholds for source reliability, counterargument quality, publishability, and source basis count before becoming a public claim.",
  },
];
const methodJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "How The Lumenary Generates Original Research Findings",
    description,
    step: methodSteps.map((step, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      text: step,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: methodFaq.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title="Research Method" description={description} jsonLd={methodJsonLd}>
  <section class="page-band">
    <p class="eyebrow">Method</p>
    <h1>How The Lumenary Thinks</h1>
    <p class="lead">
      The project treats traditions, science, and philosophy as source material for new distinctions,
      not as material to flatten into summaries.
    </p>
  </section>
  <section class="content-section">
    <div class="answer-panel">
      <p class="eyebrow">Direct answer</p>
      <h2>How Does The Lumenary Think?</h2>
      <p>
        It turns sources into claim units, compares them across traditions and science, finds convergence and strain,
        writes one original idea, then forces that idea through originality audit and critique before any public promotion.
      </p>
      <ol class="answer-steps">
        {methodSteps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>
  <section class="content-section method-grid">
    <article class="method-block">
      <h2>1. Source Grounding</h2>
      <p>Every promoted claim should cite source cards and preserve the difference between text, interpretation, analogy, and speculation.</p>
    </article>
    <article class="method-block">
      <h2>2. Translation Strain</h2>
      <p>Apparent convergence becomes interesting when the system names what must bend, disappear, or be added for two claims to align.</p>
    </article>
    <article class="method-block">
      <h2>3. Adversarial Critique</h2>
      <p>Each finding carries a critique, an anomaly probe, predictions, and scores for novelty, coherence, source reliability, practice-testability, and publishability.</p>
    </article>
    <article class="method-block">
      <h2>4. Originality Audit</h2>
      <p>Every 30-minute run searches for near-neighbors, compares primary texts directly, asks what would falsify the idea, and stores the audit under reviews/originality/.</p>
    </article>
    <article class="method-block">
      <h2>5. Agent Attribution</h2>
      <p>Codex and Claude observations remain attributed. Convergences and disagreements are preserved rather than merged away.</p>
    </article>
  </section>
  <section class="content-section">
    <div class="section-heading">
      <p class="eyebrow">Publication gate</p>
      <h2>Promotion Rules</h2>
    </div>
    <div class="method-grid">
      {promotionStages.map(([, rule]) => (
        <article class="method-block">
          <h3>{rule.label}</h3>
          <p>{rule.description}</p>
          <ul class="clean-list">
            <li>Source reliability: {rule.source_reliability.toFixed(2)}</li>
            <li>Counterargument quality: {rule.counterargument_quality.toFixed(2)}</li>
            <li>Publishability: {rule.publishability.toFixed(2)}</li>
            <li>Source basis items: {rule.min_source_basis_items}</li>
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
