---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatLabel, getInsights } from "../../lib/content";
import { collectionPageSchema, faqSchema, itemListSchema, type BreadcrumbItem } from "../../lib/seo";

const insights = getInsights();
const agents = [...new Set(insights.map((insight) => insight.agent))].sort();
const stages = [...new Set(insights.map((insight) => insight.promotionStage))].sort();
const types = [...new Set(insights.map((insight) => insight.ideaType))].sort();
const labels = [...new Set(insights.flatMap((insight) => insight.epistemicLabels))].sort();
const traditions = [...new Set(insights.flatMap((insight) => insight.traditionTags))].sort();
const description =
  "Short, plainspoken insights distilled from The Lumenary's source-grounded findings and originality audits.";
const breadcrumbs: BreadcrumbItem[] = [
  { name: "The Lumenary", path: "/" },
  { name: "Insights", path: "/insights/" },
];
const insightsFaq = [
  {
    question: "What are The Lumenary Insights?",
    answer:
      "Insights are short, reader-facing distillations of findings. They point back to the full research record rather than standing alone as separate claims.",
  },
  {
    question: "How are Insights ranked?",
    answer:
      "Insights are ranked by quality signals from the underlying finding, promotion status, and reader upvotes.",
  },
];
const jsonLd = [
  collectionPageSchema({
    name: "The Lumenary Insights",
    path: "/insights/",
    description,
    mainEntity: itemListSchema(
      "The Lumenary Insights",
      "/insights/",
      insights.slice(0, 24).map((insight) => ({
        name: insight.insight,
        path: `/findings/${insight.slug}/`,
      })),
    ),
  }),
  faqSchema(insightsFaq),
];
---

<BaseLayout title="Insights" description={description} jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <section class="page-band">
    <p class="eyebrow">Distilled wisdom</p>
    <h1>Insights</h1>
    <p class="lead">
      Short, plainspoken cards distilled from Lumenary's findings. The deeper reasoning remains in each linked finding.
    </p>
  </section>

  <section class="content-section">
    <div class="answer-panel">
      <h2>What Are These Insights?</h2>
      <p>
        Insights are the shortest expression of The Lumenary's findings. Each card is meant to be remembered,
        but the deeper claim, critique, source basis, and originality audit live on the linked Finding page.
      </p>
      <div class="answer-grid">
        {insightsFaq.map((item) => (
          <article>
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <form class="insight-filters" id="insight-filters" aria-label="Insight filters">
      <label>
        <span>View</span>
        <select name="best">
          <option value="">Best first</option>
          <option value="true">Best only</option>
        </select>
      </label>
      <label>
        <span>Agent</span>
        <select name="agent">
          <option value="">All agents</option>
          {agents.map((agent) => <option value={agent}>{agent}</option>)}
        </select>
      </label>
      <label>
        <span>Stage</span>
        <select name="stage">
          <option value="">All stages</option>
          {stages.map((stage) => <option value={stage}>{formatLabel(stage)}</option>)}
        </select>
      </label>
      <label>
        <span>Type</span>
        <select name="type">
          <option value="">All types</option>
          {types.map((type) => <option value={type}>{formatLabel(type)}</option>)}
        </select>
      </label>
      <label>
        <span>Tradition</span>
        <select name="tradition">
          <option value="">All traditions</option>
          {traditions.map((tradition) => <option value={tradition}>{formatLabel(tradition)}</option>)}
        </select>
      </label>
      <label>
        <span>Label</span>
        <select name="label">
          <option value="">All labels</option>
          {labels.map((label) => <option value={label}>{formatLabel(label)}</option>)}
        </select>
      </label>
    </form>

    <div class="insight-grid" id="insight-grid">
      {insights.map((insight, index) => {
        const best = index < 6 || insight.promotionStage === "public_claim" || insight.promotionStage === "synthesis_ready";
        return (
          <article
            class="insight-card"
            data-agent={insight.agent}
            data-best={best ? "true" : "false"}
            data-labels={insight.epistemicLabels.join(" ")}
            data-score={insight.insightScore}
            data-slug={insight.slug}
            data-stage={insight.promotionStage}
            data-traditions={insight.traditionTags.join(" ")}
            data-type={insight.ideaType}
            data-vote-aliases={[insight.slug, ...insight.legacySlugs].join(" ")}
            data-vote-key={insight.ideaId}
            data-votes="0"
          >
            <h2><a href={`/findings/${insight.slug}/`}>{insight.insight}</a></h2>
            <p>{insight.plainSummary}</p>
            <div class="insight-card-actions">
              <button
                aria-label={`Up vote ${insight.insight}`}
                class="insight-vote"
                data-vote-button
                type="button"
              >
                <span aria-hidden="true">↑</span>
                <span>Up vote</span>
                <strong data-vote-count>0</strong>
              </button>
              <time class="insight-date" datetime={insight.date}>{insight.date}</time>
            </div>
          </article>
        );
      })}
    </div>

    <p class="empty-filter-message" id="empty-filter-message" hidden>No insights match these filters.</p>
  </section>

  <script>
    const form = document.querySelector("#insight-filters");
    const grid = document.querySelector("#insight-grid");
    const cards = [...document.querySelectorAll(".insight-card")];
    const empty = document.querySelector("#empty-filter-message");
    const localVoteStoreKey = "lumenary.insightVotes.v2";

    function includesToken(value, token) {
      return !token || ` ${value || ""} `.includes(` ${token} `);
    }

    function voteCount(card) {
      const votes = Number(card.dataset.votes || 0);
      return Number.isFinite(votes) ? votes : 0;
    }

    function voteKeys(card) {
      return [
        card.dataset.voteKey,
        card.dataset.slug,
        ...(card.dataset.voteAliases || "").split(/\s+/),
      ]
        .filter(Boolean)
        .filter((key, index, keys) => keys.indexOf(key) === index);
    }

    function readLocalVotes() {
      try {
        return JSON.parse(window.localStorage.getItem(localVoteStoreKey) || "{}");
      } catch {
        return {};
      }
    }

    function writeLocalVote(card, votes) {
      const stored = readLocalVotes();
      for (const key of voteKeys(card)) {
        stored[key] = Math.max(Number(stored[key] || 0), votes);
      }
      window.localStorage.setItem(localVoteStoreKey, JSON.stringify(stored));
    }

    function localVoteCount(card) {
      const stored = readLocalVotes();
      return voteKeys(card).reduce((max, key) => {
        const votes = Number(stored[key] || 0);
        return Number.isFinite(votes) ? Math.max(max, votes) : max;
      }, 0);
    }

    function serverVoteCount(card, votesByKey) {
      const canonical = card.dataset.voteKey;
      const canonicalVotes = Number(votesByKey?.[canonical] || 0);
      if (Number.isFinite(canonicalVotes) && canonicalVotes > 0) {
        return canonicalVotes;
      }
      return voteKeys(card).reduce((total, key) => {
        const votes = Number(votesByKey?.[key] || 0);
        return Number.isFinite(votes) ? total + votes : total;
      }, 0);
    }

    function qualityScore(card) {
      const score = Number(card.dataset.score || 0);
      return Number.isFinite(score) ? score : 0;
    }

    function recentVoteTime(card) {
      const votedAt = Number(card.dataset.votedAt || 0);
      return Number.isFinite(votedAt) ? votedAt : 0;
    }

    function sortedCards() {
      return [...cards].sort((a, b) => {
        const voteRank = voteCount(b) - voteCount(a);
        if (voteRank !== 0) return voteRank;
        const recentRank = recentVoteTime(b) - recentVoteTime(a);
        if (recentRank !== 0) return recentRank;
        const rank = qualityScore(b) - qualityScore(a);
        if (rank !== 0) return rank;
        return (b.dataset.slug || "").localeCompare(a.dataset.slug || "");
      });
    }

    function syncVoteButtons() {
      for (const card of cards) {
        const votes = Number(card.dataset.votes || 0);
        const count = card.querySelector("[data-vote-count]");
        const button = card.querySelector("[data-vote-button]");
        if (count) count.textContent = String(votes);
        if (button) {
          const pending = card.dataset.votePending === "true";
          button.disabled = pending;
          button.setAttribute("aria-busy", pending ? "true" : "false");
        }
      }
    }

    function updateInsights() {
      const data = new FormData(form);
      const rankedCards = sortedCards();
      const bestSlugs = new Set(rankedCards.slice(0, 6).map((card) => card.dataset.slug));
      let visible = 0;
      for (const card of rankedCards) {
        const bestMatch = !data.get("best") || bestSlugs.has(card.dataset.slug);
        const matches =
          bestMatch &&
          (!data.get("agent") || card.dataset.agent === data.get("agent")) &&
          (!data.get("stage") || card.dataset.stage === data.get("stage")) &&
          (!data.get("type") || card.dataset.type === data.get("type")) &&
          includesToken(card.dataset.traditions, data.get("tradition")) &&
          includesToken(card.dataset.labels, data.get("label"));
        card.hidden = !matches;
        if (matches) visible += 1;
      }
      grid?.append(...rankedCards);
      empty.hidden = visible !== 0;
    }

    async function loadVotes() {
      try {
        const response = await fetch("/api/insight-votes", {
          headers: { accept: "application/json" },
        });
        if (!response.ok) return;
        const data = await response.json();
        for (const card of cards) {
          const votes = serverVoteCount(card, data.votes || {});
          const localVotes = localVoteCount(card);
          const currentVotes = voteCount(card);
          const nextVotes = Number.isFinite(votes) ? Math.max(votes, localVotes, currentVotes) : Math.max(localVotes, currentVotes);
          card.dataset.votes = String(nextVotes);
        }
      } finally {
        syncVoteButtons();
        updateInsights();
      }
    }

    async function upVote(card) {
      const slug = card.dataset.slug;
      if (!slug) return;

      const priorVotes = Number(card.dataset.votes || 0);
      const optimisticVotes = priorVotes + 1;
      card.dataset.votes = String(optimisticVotes);
      card.dataset.votedAt = String(Date.now());
      card.dataset.votePending = "true";
      writeLocalVote(card, optimisticVotes);
      syncVoteButtons();
      updateInsights();

      try {
        const key = card.dataset.voteKey || slug;
        const aliases = voteKeys(card).filter((candidate) => candidate !== key);
        const response = await fetch("/api/insight-votes", {
          body: JSON.stringify({ key, slug: key, aliases }),
          headers: {
            "content-type": "application/json",
            accept: "application/json",
          },
          method: "POST",
        });
        if (!response.ok) throw new Error("Vote request failed.");
        const data = await response.json();
        if (Number.isFinite(Number(data.votes))) {
          card.dataset.votes = String(Math.max(Number(data.votes), voteCount(card)));
          writeLocalVote(card, voteCount(card));
        }
      } catch {
        card.dataset.voteError = "true";
      } finally {
        card.dataset.votePending = "false";
        syncVoteButtons();
        updateInsights();
      }
    }

    form?.addEventListener("change", updateInsights);
    for (const button of document.querySelectorAll("[data-vote-button]")) {
      button.addEventListener("click", () => {
        const card = button.closest(".insight-card");
        if (card) upVote(card);
      });
    }
    loadVotes();
  </script>
</BaseLayout>
