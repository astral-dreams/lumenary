sources/sources_index.jsonl:117:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "Pew Research Center study on where Americans say they find meaning, including family, career, money, spirituality, faith, friends, and health. Use as grounding for meaning loss, purpose, belonging, and how teachings should meet the actual places people already look for significance.", "path": "notes/source-cards/modern-human-condition-pew-where-americans-find-meaning-in-life.md", "source_id": "modern-human-condition-pew-where-americans-find-meaning-in-life", "source_type": "report", "title": "Where Americans Find Meaning in Life", "tradition": "modern-human-condition", "url": "https://www.pewresearch.org/religion/2018/11/20/where-americans-find-meaning-in-life/"}
sources/sources_index.jsonl:118:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "Curran and Hill meta-analysis on birth cohort changes in perfectionism from 1989 to 2016. Use as grounding for achievement pressure, socially prescribed perfectionism, performance-based self-worth, comparison, shame, and why result-release practices are targeted remedies rather than universal practices.", "path": "notes/source-cards/modern-human-condition-curran-hill-perfectionism-increasing.md", "source_id": "modern-human-condition-curran-hill-perfectionism-increasing", "source_type": "paper", "title": "Perfectionism Is Increasing Over Time", "tradition": "modern-human-condition", "url": "https://doi.org/10.1037/bul0000138"}
sources/sources_index.jsonl:119:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "CDC source on suicide as a public-health problem, risk, prevention, and warning signs. Use as a safety constraint for teachings on despair, meaning, grief, disconnection, and burdensomeness. Lumenary should clearly direct acute crisis toward human emergency and clinical support.", "path": "notes/source-cards/modern-human-condition-cdc-suicide-facts.md", "source_id": "modern-human-condition-cdc-suicide-facts", "source_type": "website", "title": "Suicide Facts", "tradition": "modern-human-condition", "url": "https://www.cdc.gov/suicide/facts/index.html"}
sources/sources_index.jsonl:120:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "Gallup workplace report on employee engagement, stress, loneliness, and the quality of work life. Use as grounding for modern work as a source of identity, exhaustion, isolation, and the need for practices that distinguish responsibility from self-erasure.", "path": "notes/source-cards/modern-human-condition-gallup-state-global-workplace-2024.md", "source_id": "modern-human-condition-gallup-state-global-workplace-2024", "source_type": "report", "title": "State of the Global Workplace 2024", "tradition": "modern-human-condition", "url": "https://www.gallup.com/workplace/349484/state-of-the-global-workplace.aspx"}
