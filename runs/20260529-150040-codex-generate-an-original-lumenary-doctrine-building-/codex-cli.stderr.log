reviews/human-condition/audits.jsonl:70:{"agent": "claude", "audit_id": "e26923207b9027ed", "caution": "Do not use context-sensitivity to avoid a hard teaching that actually applies.", "confidence": 0.82, "created_at": "2026-05-28T16:03:40+02:00", "execution_id": "parallel-20260528-160005-20260528-160005", "fit_status": "direct", "idea_id": "b53b10dbe6bb091e", "keywords_matched": ["teaching", "method", "practice", "misuse", "warning", "teacher", "failure"], "next_question": "Who could be harmed if this finding were taught without naming its audience?", "non_fit": "People in active crisis or early recovery, where the practice is still doing essential stabilizing work. People whose practice is light, varied, or not identity-defining. People in acute grief. Anyone for whom releasing or relativizing a practice would remove a current safety structure.", "practical_implication": "A practice derived from this finding should ask who the lesson is for before asking whether it is true.", "primary_problem": "Identity rigidity and meaning loss in people whose self-worth has become welded to a healing or improvement practice, even after the original wound has stabilized.", "run_ids": ["20260528-160005-codex-generate-an-original-lumenary-doctrine-building-", "20260528-160005-claude-generate-an-original-lumenary-doctrine-building-"], "source_card_ids": ["modern-human-condition-who-world-mental-health-report", "modern-human-condition-surgeon-general-social-connection-advisory"], "target_cohort": "Long-term participants in a single defining practice (therapy, twelve-step recovery, daily meditation, structured self-improvement) at least three years in, where the original presenting problem is no longer acute.", "title": "Three ways a practice can end", "why_it_matters": "It keeps doctrine from becoming a weapon by forcing every lesson to remember its intended audience."}
