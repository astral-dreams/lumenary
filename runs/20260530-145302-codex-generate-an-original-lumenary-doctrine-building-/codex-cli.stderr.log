./reviews/human-condition/audits.jsonl:73:{"agent": "claude", "audit_id": "2105e0251a3acaf1", "caution": "Do not use philosophy of time to rush mourning or escape a real loss.", "confidence": 0.9, "created_at": "2026-05-29T06:22:34+02:00", "execution_id": "parallel-20260529-061525-20260529-061525", "fit_status": "direct", "idea_id": "55b9fb5b3cf91595", "keywords_matched": ["time", "temporal", "being-time", "change", "loss", "memory"], "next_question": "Does this finding help a person meet change more truthfully, or does it abstract away the pain?", "non_fit": "Not for acute crisis, active suicidality, psychosis, severe dissociation requiring stabilization, active addiction withdrawal, or people whose suffering does not include felt time-distortion. Not a substitute for grief counseling, trauma therapy, medical care, or human company. If reaching for the past triggers flashbacks, panic, or strong dissociation, stop and seek a trauma-informed clinician.", "practical_implication": "A practice derived from this finding should let grief and change be observed without forcing consolation.", "primary_problem": "Subjective time has become stuck, blurred, gapped, or stopped after bereavement, severe depression, trauma, or burnout collapse.", "run_ids": ["20260529-061525-claude-probe-the-reality-of-time-use-this-exchange-betw", "20260529-061525-codex-probe-the-reality-of-time-use-this-exchange-betw"], "source_card_ids": ["modern-human-condition-who-world-mental-health-report", "modern-human-condition-apa-stress-in-america-2024", "modern-human-condition-cdc-suicide-facts"], "target_cohort": "Adults in stable enough condition to do a short reflective exercise, who notice that their lived time has changed shape and that hours, days, or weeks no longer feel right.", "title": "Why Grief Stops Time", "why_it_matters": "It can help distinguish insight about change from pressure to become peaceful too quickly."}
