./sources/sources_index.jsonl:110:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "U.S. Surgeon General advisory on loneliness, isolation, social connection, belonging, health risk, and community repair. Use as a grounding source for teachings and practices aimed at disconnection, feeling unneeded, social withdrawal, and the loss of ordinary belonging.", "path": "notes/source-cards/modern-human-condition-surgeon-general-social-connection-advisory.md", "source_id": "modern-human-condition-surgeon-general-social-connection-advisory", "source_type": "report", "title": "Our Epidemic of Loneliness and Isolation", "tradition": "modern-human-condition", "url": "https://www.hhs.gov/sites/default/files/surgeon-general-social-connection-advisory.pdf"}
./sources/sources_index.jsonl:111:{"created_at": "2026-05-26T17:05:00-07:00", "notes": "World Health Organization report on mental health burden, social determinants, treatment gaps, stigma, and the need to transform care. Use as grounding for anxiety, depression, isolation, suffering, structural pressure, and teachings that must not pretend spiritual practice replaces clinical care.", "path": "notes/source-cards/modern-human-condition-who-world-mental-health-report.md", "source_id": "modern-human-condition-who-world-mental-health-report", "source_type": "report", "title": "World Mental Health Report", "tradition": "modern-human-condition", "url": "https://www.who.int/publications/i/item/9789240049338"}
